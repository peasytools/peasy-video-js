{
  "name": "peasy-video-js",
  "version": "0.1.1",
  "description": "Video processing library for Node.js — trim, resize, rotate, thumbnails, GIF conversion. FFmpeg-powered, TypeScript-first.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "build": "tsup src/index.ts --format esm --dts",
    "test": "vitest run",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "video",
    "mp4",
    "ffmpeg",
    "trim",
    "resize",
    "thumbnail",
    "gif",
    "peasy"
  ],
  "author": "Peasy Tools",
  "license": "MIT",
  "repository": {
    "url": "https://github.com/peasytools/peasy-video-js.git"
  },
  "homepage": "https://peasyvideo.com",
  "dependencies": {
    "fluent-ffmpeg": "^2.1"
  },
  "devDependencies": {
    "@types/fluent-ffmpeg": "^2.1",
    "tsup": "^8.0",
    "typescript": "^5.7",
    "vitest": "^3.0"
  }
}
